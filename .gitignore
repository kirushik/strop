/target

# Local Claude Code working state (machine-specific, not part of the project)
.claude/worktrees/
.claude/*.lock
.claude/settings.local.json

# Working documents (Loro snapshots) — never commit a user's file
*.strop
*.strop.tmp
# The committed corpus fixtures are the one exception to the dogfooding
# ignore above: frozen released-format bytes (releasing.md §6.3).
!crates/strop-core/tests/corpus/*.strop
target-main/
packaging/generated/

# Signing secrets — NEVER commit. The update-signing minisign PUBLIC key
# (minisign.pub) is deliberately exempt below; everything here is private.
*.key
*.p12
*.p8
AuthKey_*
minisign.key
!minisign.pub
