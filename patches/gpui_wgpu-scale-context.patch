+        // STROP PATCH (the only Strop change in this crate — see
+        // docs/UPSTREAM-gpui-scale-bug.md and patches/README.md in Strop):
+        // rasterize with a FRESH ScaleContext instead of the long-lived
+        // shared one upstream keeps in CosmicTextSystemState (the field is
+        // removed here). The shared context's internal caches
+        // make rasterization non-deterministic across a window scale
+        // change: after this font has been scaled at another device scale,
+        // identical RenderGlyphParams yield subtly different (≈1px
+        // smaller, mis-hinted) bitmaps than a fresh context produces.
+        // The sprite atlas then caches those poisoned tiles for the
+        // lifetime of the window — the persistent "wrong-size glyphs
+        // mid-word" corruption after moving a Wayland window between
+        // monitors of different scales. Proven by per-tile content
+        // hashing and by this very intervention (scripts/wflip.sh goes
+        // from deterministic-red to green). Cost: hint-cache rebuild per
+        // rasterized glyph — only on atlas misses, negligible here.
+        let mut fresh_scale_context = ScaleContext::new();
+        let mut scaler = fresh_scale_context
             .builder(font_ref)
